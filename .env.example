# ZillaSoft Local Manager — environment template (safe to commit).
# Copy to .env and fill in. Secrets are <FILL>; infra IDs and machine-specific
# paths are placeholders here and live only in the gitignored .env.

# ============ API KEYS & CREDENTIALS (Mario-only; agents cannot write) ============
ANTHROPIC_API_KEY=<FILL>

# Sentry (error tracking)
SENTRY_AUTH_TOKEN=<FILL>
SENTRY_ORG=<FILL>
SENTRY_PROJECT_WEBSITE=zillasoft-website
SENTRY_PROJECT_SNIPZILLA=snipzilla-app
SENTRY_PROJECT_STASHZILLA=stashzilla-app

# Jira (issue tracking)
JIRA_HOST=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=<FILL>
JIRA_PROJECT_KEY=SUPPORT
JIRA_BOARD_ID=1

# GitHub
GITHUB_TOKEN=<FILL>
GITHUB_OWNER=ZillaSoft-io
GITHUB_EMAIL=you@example.com

# Railway
RAILWAY_API_TOKEN=<FILL>
RAILWAY_PROJECT_SNIPZILLA=<FILL>
RAILWAY_PROJECT_STASHZILLA=<FILL>
RAILWAY_SERVICE_SNIPZILLA=<FILL>
RAILWAY_SERVICE_STASHZILLA=<FILL>

# AWS (S3 + CloudFront)
AWS_ACCESS_KEY_ID=<FILL>
AWS_SECRET_ACCESS_KEY=<FILL>
AWS_S3_BUCKET_WEBSITE=<FILL>
AWS_S3_BUCKET_DOWNLOADS=<FILL>
AWS_CLOUDFRONT_DISTRIBUTION_WEBSITE=<FILL>
AWS_CLOUDFRONT_DISTRIBUTION_DOWNLOADS=<FILL>

# GitHub Actions repos
GITHUB_ACTIONS_REPO_WEBSITE=ZillaSoft-io/Zillasoft
GITHUB_ACTIONS_REPO_SNIPZILLA=ZillaSoft-io/Snipzilla
GITHUB_ACTIONS_REPO_STASHZILLA=ZillaSoft-io/Stashzilla

# ============ MODEL CONFIGURATION ============
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8
ANTHROPIC_EFFORT_HAIKU=medium
ANTHROPIC_EFFORT_SONNET=medium
ANTHROPIC_EFFORT_OPUS=high

# ============ PROJECT: ZILLASOFT WEBSITE ============
PROJECT_WEBSITE_REPO=Zillasoft
PROJECT_WEBSITE_REPO_PATH=/path/to/Zillasoft
PROJECT_WEBSITE_GITHUB_REPO=ZillaSoft-io/Zillasoft
PROJECT_WEBSITE_GITHUB_BRANCH=main
PROJECT_WEBSITE_FRAMEWORK=astro
PROJECT_WEBSITE_BUILD_COMMAND=pnpm build
PROJECT_WEBSITE_TEST_COMMAND=pnpm test
PROJECT_WEBSITE_DEPLOY_TRIGGER=github_actions_manual
PROJECT_WEBSITE_GITHUB_ACTIONS_WORKFLOW=deploy-site.yml
PROJECT_WEBSITE_HEALTH_CHECK_URL=https://zillasoft.io/status
PROJECT_WEBSITE_HEALTH_CHECK_FORMAT=html
PROJECT_WEBSITE_HEALTH_CHECK_EXPECTED_STATUS=200
PROJECT_WEBSITE_S3_BUCKET=<FILL>
PROJECT_WEBSITE_S3_REGION=us-east-1
PROJECT_WEBSITE_CLOUDFRONT_DISTRIBUTION=<FILL>
PROJECT_WEBSITE_CLOUDFRONT_INVALIDATE_PATHS=/*

# ============ PROJECT: SNIPZILLA ============
PROJECT_SNIPZILLA_REPO=Snipzilla
PROJECT_SNIPZILLA_REPO_PATH=/path/to/Snipzilla/snipzilla
PROJECT_SNIPZILLA_GITHUB_REPO=ZillaSoft-io/Snipzilla
PROJECT_SNIPZILLA_GITHUB_BRANCH=master
PROJECT_SNIPZILLA_FRAMEWORK=python_pyqt5_fastapi
PROJECT_SNIPZILLA_BUILD_COMMAND=build_win.bat
PROJECT_SNIPZILLA_TEST_COMMAND=pytest tests/ -v
PROJECT_SNIPZILLA_DEPLOY_TRIGGER=railway
PROJECT_SNIPZILLA_RAILWAY_PROJECT_ID=<FILL>
PROJECT_SNIPZILLA_RAILWAY_SERVICE_ID=<FILL>
PROJECT_SNIPZILLA_HEALTH_CHECK_URL=https://api.snipzilla.app/health
PROJECT_SNIPZILLA_HEALTH_CHECK_FORMAT=json
PROJECT_SNIPZILLA_HEALTH_CHECK_JSON_KEY=status
PROJECT_SNIPZILLA_HEALTH_CHECK_EXPECTED_VALUE=healthy
PROJECT_SNIPZILLA_HEALTH_CHECK_EXPECTED_STATUS=200
PROJECT_SNIPZILLA_GITHUB_ACTIONS_WORKFLOW=release-windows.yml

# ============ PROJECT: STASHZILLA ============
PROJECT_STASHZILLA_REPO=Stashzilla
PROJECT_STASHZILLA_REPO_PATH=/path/to/Stashzilla/stashzilla
PROJECT_STASHZILLA_GITHUB_REPO=ZillaSoft-io/Stashzilla
PROJECT_STASHZILLA_GITHUB_BRANCH=master
PROJECT_STASHZILLA_FRAMEWORK=python_fastapi
PROJECT_STASHZILLA_BUILD_COMMAND=pip install -e .
PROJECT_STASHZILLA_TEST_COMMAND=pytest tests/ -v
PROJECT_STASHZILLA_DEPLOY_TRIGGER=railway
PROJECT_STASHZILLA_RAILWAY_PROJECT_ID=<FILL>
PROJECT_STASHZILLA_RAILWAY_SERVICE_ID=<FILL>
PROJECT_STASHZILLA_HEALTH_CHECK_URL=https://api.stashzilla.app/health
PROJECT_STASHZILLA_HEALTH_CHECK_FORMAT=json
PROJECT_STASHZILLA_HEALTH_CHECK_JSON_KEY=status
PROJECT_STASHZILLA_HEALTH_CHECK_EXPECTED_VALUE=ok
PROJECT_STASHZILLA_HEALTH_CHECK_EXPECTED_STATUS=200
PROJECT_STASHZILLA_GITHUB_ACTIONS_WORKFLOW=<FILL>

# ============ LOCAL MANAGER SETTINGS ============
LOCAL_MANAGER_DB_PATH=./local_manager.db
LOCAL_MANAGER_AUDIT_LOG_PATH=./audit_logs/
LOCAL_MANAGER_PORT=5555
LOCAL_MANAGER_HOST=localhost
LOCAL_MANAGER_LOG_LEVEL=INFO
LOCAL_MANAGER_MONTHLY_COST_CAP=100.00
LOCAL_MANAGER_CURRENT_MONTH_SPENT=0.00
LOCAL_MANAGER_COST_RESET_MONTH=2026-06
LOCAL_MANAGER_MAX_CYCLES=3
LOCAL_MANAGER_ROLLBACK_REQUIRE_APPROVAL=true
LOCAL_MANAGER_AUTO_COMMIT=false
LOCAL_MANAGER_AUTO_DEPLOY=false
LOCAL_MANAGER_PAUSE_EXPIRY_DAYS=7
LOCAL_MANAGER_AUTH_TOKEN=<AUTO>

# ============ NOTIFICATIONS ============
NOTIFICATIONS_DESKTOP_ENABLED=true
NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_EMAIL_TO=you@example.com
NOTIFICATIONS_EMAIL_ON_SUCCESS=true
NOTIFICATIONS_EMAIL_ON_FAILURE=true
NOTIFICATIONS_EMAIL_ON_ESCALATION=true
BREVO_API_KEY=<FILL>
BREVO_SENDER_EMAIL=noreply@zillasoft.io
